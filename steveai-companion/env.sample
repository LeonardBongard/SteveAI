# Copy this file to .env and edit as needed:
#   cp env.sample .env

# --- Minecraft server ---
# Default assumes you've opened your singleplayer world to LAN, or are running a
# local server. The LAN port changes each time you "Open to LAN"; for stable
# development, run a local PaperMC/Fabric server on 25565 instead.
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=Steve
# Server version Mineflayer should target. "false" auto-detects.
MC_VERSION=false
# offline-mode=true on the server lets us connect without Mojang auth.
MC_AUTH=offline

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
# Primary model — see docs/COMPANION_V1_DIRECTION.md §3.2.
OLLAMA_MODEL=gpt-oss:20b
# Embedding model used for memory retrieval.
OLLAMA_EMBED_MODEL=nomic-embed-text
# Keep model loaded between turns. 30m is the M3-Pro-Max-with-Minecraft-running default.
# Bump to "24h" or "-1" if you have headroom; set to "0" to free memory aggressively.
OLLAMA_KEEP_ALIVE=30m

# --- Bot behavior ---
# How verbose pino logs should be: trace | debug | info | warn | error
LOG_LEVEL=info
# Per-turn LLM context budget (rough guard).
MAX_CONTEXT_TOKENS=4096
# How many recent chat turns to keep verbatim in the sliding window.
MEMORY_WINDOW_TURNS=20
# How many top-K memories to retrieve per turn.
MEMORY_TOP_K=4
