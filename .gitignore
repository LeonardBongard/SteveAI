# Project-wide gitignore. Per-subdirectory .gitignore files (e.g.
# steveai-companion/.gitignore) handle their own subtrees.

# Editor / OS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
.idea/
*.iml
.vscode/
*.code-workspace

# Local notes / scratch
brain.md
*.local.md
temp_memory_chatgpt.txt

# Forge runtime config (kept at repo root; contains API keys)
config/steve-common.toml
run/config/steve-common.toml

# Defensive: Node outputs at the root (active project lives in
# steveai-companion/ which has its own .gitignore).
node_modules/
dist/

# Defensive: Forge / Gradle outputs in case they regenerate at the root.
# (Active Forge sources live under legacy/forge-mod/ now.)
bin/
build/
.gradle/
out/
mcmodsrepo/
generated/
reports/
logs/
run/
jdk-17.0.2.jdk/

# Misc
*.log
*.mp4
*.mov
*.avi
*.webm
*.nbt
